{
  "name": "portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "moon run :build",
    "check-all": "pnpm run lint && pnpm run types && pnpm run madge && pnpm run test && pnpm run format-check && pnpm run sort-package-json-check",
    "coverage": "vitest run --coverage",
    "predeploy": "pnpm build",
    "deploy": "gh-pages -d apps/portfolio/dist",
    "dev": "moon run portfolio:dev",
    "format": "biome format --write .",
    "format-check": "biome format .",
    "lint": "biome check .",
    "lint-fix": "biome check --write .",
    "madge": "moon run :madge",
    "prepare": "husky",
    "setup": "moon setup",
    "sort-package-json": "sort-package-json package.json 'apps/*/package.json' 'libs/*/package.json'",
    "sort-package-json-check": "sort-package-json package.json 'apps/*/package.json' 'libs/*/package.json' --check",
    "test": "vitest run",
    "types": "moon run :type-check"
  },
