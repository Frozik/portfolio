{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "apps/**/*.{ts,tsx,js,jsx,json}",
      "libs/**/*.{ts,tsx,js,jsx,json}",
      "*.{ts,tsx,js,jsx,json}",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/dev-dist",
      "!!**/build",
      "!!**/coverage",
      "!!**/storybook-static",
      "!!apps/retro",
      "!!.moon",
      "!!.claude",
      "!!.nx",
      "!!pnpm-lock.yaml"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "semicolons": "always",
      "quoteStyle": "single",
      "trailingCommas": "es5",
      "arrowParentheses": "asNeeded",
      "bracketSpacing": true,
      "bracketSameLine": false
    }
  },
  "linter": {
    "rules": {
      "suspicious": {
        "noExplicitAny": "warn",
        "noApproximativeNumericConstant": "error",
        "noAssignInExpressions": "off",
        "noImplicitAnyLet": "warn",
        "noTemplateCurlyInString": "off",
        "useIterableCallbackReturn": "off",
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["assert", "time", "timeEnd"]
          }
        },
        "noFocusedTests": "error",
        "noSkippedTests": "warn",
        "useErrorMessage": "error",
        "noShadowRestrictedNames": "warn",
        "noArrayIndexKey": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "separatedType"
          }
        },
        "noDefaultExport": "error",
        "useBlockStatements": "error",
        "noUselessElse": "warn",
        "useThrowNewError": "warn",
        "useConsistentBuiltinInstantiation": "warn",
        "useNumberNamespace": "warn",
        "useSelfClosingElements": "warn",
        "useFilenamingConvention": "off",
        "useNamingConvention": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "**/features/*/components/**",
                  "**/features/*/hooks/**",
                  "**/features/*/sagas/**",
                  "**/features/*/modules/**"
                ],
                "message": "Import from the feature public API (features/*/index.ts or features/*/FeatureName.tsx) instead of reaching into feature internals."
              }
            ]
          }
        }
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "error",
        "noVoidTypeReturn": "error",
        "useExhaustiveDependencies": "warn",
        "useHookAtTopLevel": "error",
        "noUnusedFunctionParameters": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "warn"
      },
      "security": {
        "noDangerouslySetInnerHtml": "warn"
      },
      "complexity": {
        "noForEach": "off",
        "noStaticOnlyClass": "off",
        "useLiteralKeys": "off"
      },
      "a11y": {
        "noSvgWithoutTitle": "off",
        "useButtonType": "off",
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useKeyWithMouseEvents": "off"
      }
    }
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/*.test.ts",
        "**/*.spec.ts",
        "**/*.test.tsx",
        "**/*.spec.tsx"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["*.json"],
      "formatter": {
        "lineWidth": 80
      }
    },
    {
      "includes": ["**/vite.config.ts", "**/vitest.config.ts"],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    }
  ]
}
