{
  "name": "@frozik/portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true tsc -b && ANALYZE=true vite build",
    "build": "tsc -b && vite build && cp dist/index.html dist/404.html",
    "preview": "vite preview",
    "serve": "vite",
    "serve-https": "HTTPS=true vite",
    "types": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@frozik/components": "workspace:*",
    "@frozik/utils": "workspace:*"
  },
  "devDependencies": {
    "@frozik/typescript-config": "workspace:*"
  }
}
